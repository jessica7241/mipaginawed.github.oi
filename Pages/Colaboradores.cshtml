@page
@model Sistemas.Solution.Pages.ColaboradoresModel

<section class="colaboradores">

    <h2>Nuestro Equipo</h2>

    <div class="cards">

        

        <div class="flip-card">

            <div class="flip-card-inner">

                <div class="flip-card-front">

                    <img src="~/images/jefe.jpg" alt="Jefe">

                    <h3>Roberto Alexander Calderón Reyes</h3>

                    <p>Jefe General</p>

                    <button onclick="this.closest('.flip-card').classList.toggle('active')">
                        Ver Más
                    </button>

                </div>

                <div class="flip-card-back">

                    <h3>Jefe General</h3>

                    <p>
                        Responsable de la dirección general de la empresa,
                        toma de decisiones estratégicas y supervisión
                        de todas las áreas.
                    </p>

                    <button onclick="this.closest('.flip-card').classList.toggle('active')">
                        Regresar
                    </button>

                </div>

            </div>

        </div>

     

        <div class="flip-card">

            <div class="flip-card-inner">

                <div class="flip-card-front">

                    <img src="~/images/gerente.jpeg" alt="Gerente">

                    <h3>Johanna Saraí Maravilla Morales</h3>

