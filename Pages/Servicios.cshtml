@page
@model Sistemas.Solution.Pages.ServiciosModel

<section class="servicios" id="servicios">

    <h2>Nuestros Servicios</h2>

    <div class="cards">

      

        <div class="flip-card">

            <div class="flip-card-inner">

               

                <div class="flip-card-front">

                    <h3>Sistema POS</h3>

                    <img src="~/images/POS.jpg" alt="Sistema POS">

                    <p>
                        Controla ventas, inventario y productos
                        de forma rápida y segura.
                    </p>

                    <button onclick="this.closest('.flip-card').classList.toggle('active')">
                        Ver Más
                    </button>

                </div>

               

                <div class="flip-card-back">

                    <h3>Sistema POS</h3>

                    <p>
                        Nuestro sistema POS permite administrar
                        ventas, clientes, productos y generar
                        reportes automáticos en tiempo real.
                    </p>

                    <button onclick="this.closest('.flip-card').classList.toggle('active')">
                        Regresar
                    </button>

                </div>

            </div>

        </div>

       
        <div class="flip-card">

            <div class="flip-card-inner">

                <div class="flip-card-front">

                    <h3>Control de Inventario</h3>

                    <img src="~/images/controlinvetario.png" alt="Inventario">

                    <p>
                        Administra entradas y salidas en tiempo real.
                    </p>

                    <button onclick="this.closest('.flip-card').classList.toggle('active')">
                        Ver Más
                    </button>

                </div>

                <div class="flip-card-back">

                    <h3>Inventario</h3>

                    <p>
                        Controla stock, movimientos de productos,
                        alertas de inventario y reportes detallados.
                    </p>

                    <button onclick="this.closest('.flip-card').classList.toggle('active')">
                        Regresar
                    </button>

                </div>

            </div>

        </div>

     

        <div class="flip-card">

            <div class="flip-card-inner">

                <div class="flip-card-front">

                    <h3>Facturación</h3>

                    <img src="~/images/facturacion.jpg" alt="Facturación">

                    <p>
                        Genera reportes y facturas automáticamente.
                    </p>

                    <button onclick="this.closest('.flip-card').classList.toggle('active')">
                        Ver Más
                    </button>

                </div>

                <div class="flip-card-back">

                    <h3>Facturación</h3>

                    <p>
                        Crea facturas electrónicas, administra
                        clientes y obtén reportes financieros
                        automáticamente.
                    </p>

                    <button onclick="this.closest('.flip-card').classList.toggle('active')">
                        Regresar
                    </button>

                </div>

            </div>

        </div>

    </div>

</section>
